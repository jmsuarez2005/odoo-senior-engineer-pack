<odoo>
    <data noupdate="1">

        <record id="module_category_overtime" model="ir.module.category">
            <field name="name">Overtime</field>
            <field name="sequence">30</field>
        </record>

        <record id="group_overtime_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_overtime"/>
            <field name="comment">Submit own overtime; view own.</field>
        </record>

        <record id="group_overtime_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_overtime"/>
            <field name="implied_ids" eval="[(4, ref('group_overtime_user'))]"/>
            <field name="comment">Approve/refuse overtime; view all in company.</field>
        </record>

    </data>
</odoo>
